	PLTYPE_ANYNC      = PLTYPE_NC
	PLTYPE_ANYCONTROL = PLTYPE_ANYRC | PLTYPE_ANYNC
	PLTYPE_ANYPLAYER  = PLTYPE_ANYCLIENT | PLTYPE_ANYRC
	PLTYPE_NONITERABLE = PLTYPE_NPCSERVER | PLTYPE_ANYNC | PLTYPE_EXTERNAL
)

